{
  "enabledPlugins": {
    "expo@claude-plugins-official": true
  },
  "permissions": {
    "allow": [
      "Bash(git status)",
      "Bash(git branch:*)",
      "Bash(git log:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push origin dev)"
    ],
    "deny": [
      "Bash(git push origin main)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Write(peolia-admin.html)",
      "Write(**/peolia-admin.html)",
      "Edit(peolia-admin.html)",
      "Edit(**/peolia-admin.html)",
      "Read(.env)",
      "Read(**/.env)"
    ]
  }
}
